BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen3.6-35b-a3b
MODEL_TEMPERATURE=0.25
ALLOW_LOCAL_FALLBACK=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
