LLM_PROVIDER=bailian
BAILIAN_API_KEY=your_compatible_api_key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen3.6-flash-2026-04-16
MODEL_TEMPERATURE=0.25
ALLOW_LOCAL_FALLBACK=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_REVISIONS=2
PASS_SCORE=7.2

# 知识库后端：默认使用本地 TurboVec/NumPy 检索，不需要外部知识库 API Key。
KNOWLEDGE_BACKEND=local_turbovec
TURBOVEC_DB_PATH=
TURBOVEC_INDEX_PATH=
TURBOVEC_DIM=512
TURBOVEC_BIT_WIDTH=4
TURBOVEC_DEFAULT_TOP_K=6
TURBOVEC_DEFAULT_DATASET_IDS=


